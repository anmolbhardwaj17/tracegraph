####################
# DATABASE
####################
# Defaults match the bundled docker-compose service.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tracegraph
POSTGRES_PASSWORD=tracegraph
POSTGRES_DB=tracegraph

####################
# REDIS
####################
# Used for CH response cache, rate limiter, and BullMQ queue.
REDIS_HOST=localhost
REDIS_PORT=6379

####################
# NEO4J (optional)
####################
# Only needed for advanced graph algorithms (--profile graph).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tracegraph

####################
# API SERVER
####################
PORT=7778

# CHANGE THIS IN PRODUCTION — used to sign JWT auth tokens
JWT_SECRET=tracegraph-dev-secret-change-in-production

####################
# REQUIRED: Companies House
####################
# Free API key — https://developer.company-information.service.gov.uk/
# Required for all UK company investigations.
COMPANIES_HOUSE_API_KEY=

####################
# REQUIRED: OpenRouter (AI)
####################
# Free tier available — https://openrouter.ai/keys
# Powers Tracey AI chat and IC memo generation.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

####################
# OPTIONAL: Email alerts (Resend)
####################
# Free tier: 100 emails/day — https://resend.com
# Required for watchlist email notifications.
# RESEND_API_KEY=re_your_key_here
# ADMIN_ALERT_EMAIL=alerts@yourfirm.com
# APP_URL=http://localhost:3000

####################
# OPTIONAL: Google OAuth
####################
# Enables "Login with Google" — create at console.cloud.google.com
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

####################
# OPTIONAL: OpenCorporates
####################
# Improves non-UK company coverage — https://opencorporates.com/api_accounts/new
# OPENCORPORATES_API_KEY=your_token_here

####################
# OPTIONAL: Logo.dev
####################
# Higher-quality company logos — https://logo.dev
# LOGO_DEV_TOKEN=pk_your_token_here

####################
# OPTIONAL: Stripe (billing)
####################
# Required only if you want paid subscription tiers.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

####################
# WEB (Next.js)
####################
# URL the browser uses to reach the API.
# For docker-compose: http://localhost:7778
# For local dev: http://localhost:7778
NEXT_PUBLIC_API_URL=http://localhost:7778

# Google OAuth (for Login with Google button)
# Create at console.cloud.google.com → OAuth 2.0 credentials
# Authorized origins: http://localhost:3000
# Authorized redirect URIs: http://localhost:3000/auth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
