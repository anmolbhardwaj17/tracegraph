####################
# PostgreSQL
####################
# Connection details for the primary relational store. Defaults match the
# bundled docker-compose service.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tracegraph
POSTGRES_PASSWORD=tracegraph
POSTGRES_DB=tracegraph

####################
# Redis
####################
# Used for the Companies House response cache, the token-bucket rate
# limiter, and the BullMQ investigation queue.
REDIS_HOST=localhost
REDIS_PORT=6379

####################
# Neo4j
####################
# Reserved for graph algorithm execution beyond Phase 4. Not currently
# required for the core pipeline but the docker-compose service runs by
# default.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tracegraph

####################
# Companies House
####################
# Free API key from https://developer.company-information.service.gov.uk/
# If unset the API still boots, but live investigations will fail with 401.
# Run `npm run seed:demo` from apps/api to load the demo investigation that
# works without an API key.
COMPANIES_HOUSE_API_KEY=

####################
# API
####################
# Port the NestJS API listens on.
PORT=4000

####################
# Auth
####################
# JWT secret for auth tokens. CHANGE THIS IN PRODUCTION.
JWT_SECRET=tracegraph-dev-secret-change-in-production

# Google OAuth (optional — for "Login with Google")
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe (optional — for paid subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid (optional — for email alerts)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=alerts@tracegraph.com

####################
# Web
####################
# Origin used by the Next.js client to reach the API. When running outside
# Docker keep this as http://localhost:4000.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Logo.dev (optional - higher quality company logos)
# Sign up at https://logo.dev for a free API key
# LOGO_DEV_TOKEN=pk_your_token_here

# OpenCorporates (free public benefit API key)
# Apply at https://opencorporates.com/api_accounts/new
# OPENCORPORATES_API_KEY=your_token_here
